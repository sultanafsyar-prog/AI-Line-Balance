generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS & AUTH ───────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(TEAM_LEADER)
  building  String?  // untuk Manager: akses 1 gedung, null = semua gedung
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actuals   Actual[]
  lineAccess UserLine[] // Team Leader: line yang bisa diakses
}

// Relasi User ↔ Line (untuk Team Leader)
model UserLine {
  id     String @id @default(cuid())
  userId String
  lineId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  line Line @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@unique([userId, lineId])
}

enum Role {
  IE_ADMIN
  IE_OPERATOR
  TEAM_LEADER   // input aktual, hanya line miliknya
  MANAGEMENT    // view semua / per gedung, no input
  IT_ADMIN
  PPIC
}

// ─── MODEL SEPATU ───────────────────────────────────────────
model ShoeModel {
  id           String   @id @default(cuid())
  name         String   @unique
  article      String
  stage        String   @default("Production CFM")
  lineType     LineType @default(MINI)
  active       Boolean  @default(true)
  uploadedFrom String?
  imageUrl     String?  // URL foto model (disimpan di Supabase Storage)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sections    Section[]
  assignments LineAssignment[]
}

enum LineType {
  MINI // 100 pairs/jam, takt 36s
  BIG  // 180 pairs/jam, takt 20s
}

model DailyTarget {
  id          String   @id @default(cuid())
  lineId      String
  line        Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)
  date        String
  targetPairs Int
  setBy       String
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([lineId, date])
  @@index([date])
}

// ─── SECTION PER MODEL ───────────────────────────────────────
model Section {
  id           String @id @default(cuid())
  modelId      String
  name         String
  stdMP        Float
  taktTime     Float
  hourlyTarget Int?   // target/jam dari tim IE — null = pakai 3600/taktTime

  model      ShoeModel   @relation(fields: [modelId], references: [id], onDelete: Cascade)
  operations Operation[]
  actuals    Actual[]

  @@unique([modelId, name])
}

// ─── OPERASI PER SECTION ─────────────────────────────────────
model Operation {
  id        String @id @default(cuid())
  sectionId String
  seq       Int
  name      String
  va        Float  @default(0)
  nvan      Float  @default(0)
  nva       Float  @default(0)
  mcCT      Float  @default(0)
  allowance Float  @default(0.15)

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId, seq])
}

// ─── LINI PRODUKSI ───────────────────────────────────────────
model Line {
  id       String   @id @default(cuid())
  building String
  lineNo   Int
  lineType LineType @default(MINI)
  active   Boolean  @default(true)

  assignments LineAssignment[]
  actuals     Actual[]
  alerts      Alert[]
  userAccess  UserLine[]
  dailyTargets DailyTarget[] 

  @@unique([building, lineNo])
  @@index([building])
}

// ─── ASSIGNMENT MODEL KE LINE ────────────────────────────────
model LineAssignment {
  id         String   @id @default(cuid())
  lineId     String
  modelId    String
  assignedAt DateTime @default(now())
  assignedBy String
  active     Boolean  @default(true)

  line  Line      @relation(fields: [lineId], references: [id])
  model ShoeModel @relation(fields: [modelId], references: [id])

  @@index([lineId, active])
}

// ─── DATA AKTUAL PRODUKSI (per jam) ──────────────────────────
model Actual {
  id          String   @id @default(cuid())
  lineId      String
  sectionId   String
  date        String
  hour        Int
  output      Int
  mpActual    Int
  downtime    Int      @default(0)
  dtReason    String?
  defect      Int      @default(0)
  inputBy     String
  shiftClosed Boolean  @default(false) // true setelah shift di-close, data tidak boleh diubah
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  line    Line    @relation(fields: [lineId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])
  user    User    @relation(fields: [inputBy], references: [id])

  @@unique([lineId, sectionId, date, hour])
  @@index([lineId, date])
  @@index([lineId, date, shiftClosed])
}

// ─── ARSIP SHIFT (audit log untuk shift yang ditutup) ─────
model ShiftArchive {
  id           String   @id @default(cuid())
  lineId       String
  date         String
  shiftLabel   String
  closedBy     String   // user id IE Admin yang tutup shift
  closedAt     DateTime @default(now())
  totalOutput  Int
  totalDT      Int
  totalDefect  Int
  avgLler      Int
  managerEmail String?
  emailSent    Boolean  @default(false)

  @@index([lineId, date])
  @@index([closedAt])
}

// ─── ALERT ───────────────────────────────────────────────────
model Alert {
  id          String    @id @default(cuid())
  lineId      String
  type        AlertType
  message     String
  triggeredAt DateTime  @default(now())
  resolvedAt  DateTime?
  resolved    Boolean   @default(false)

  line Line @relation(fields: [lineId], references: [id])

  @@index([lineId, resolved])
}

enum AlertType {
  OUTPUT_LOW
  BOTTLENECK
  DOWNTIME_HIGH
  DEFECT_HIGH
}
